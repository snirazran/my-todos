+
+    /// A circular progress ring echoing Apple's Timer Live Activity. iOS does
+    /// not expose an auto-animating *circular* countdown to third parties
+    /// (`ProgressView(.circular)` ignores `timerInterval`), so this draws a
+    /// fixed-size `Circle().trim` whose fraction is computed at render time from
+    /// the start…end window. It refreshes whenever the activity is recreated
+    /// (start / pause / resume / phase change). When paused the ring fades and
+    /// shows a centered pause glyph, exactly like Apple's.
+    static func buildCircularTimerView(_ element: LayoutElement, _ data: [String: AnyCodable]) -> AnyView {
+        let color = getString(from: resolveValue(element.properties["color"], with: data)) ?? "#007AFF"
+        let size = getDouble(from: resolveValue(element.properties["size"], with: data)) ?? 22
+        let lineWidth = CGFloat(getDouble(from: resolveValue(element.properties["lineWidth"], with: data)) ?? 3)
+        let paused = resolveValue(element.properties["paused"], with: data) as? Bool ?? false
+        // The system circular ProgressView can't be sized reliably, so callers
+        // that need an exact size (the big expanded ring) opt out of the live
+        // animation and get the static, precisely-sized snapshot ring instead.
+        let animated = resolveValue(element.properties["animated"], with: data) as? Bool ?? true
+
+        let startTime = getDouble(from: resolveValue(element.properties["startTime"], with: data))
+        let endTime = getDouble(from: resolveValue(element.properties["endTime"], with: data))
+
+        // Fraction remaining: prefer explicit value/total, else derive from the
+        // start…end window at render time.
+        var fraction = getDouble(from: resolveValue(element.properties["value"], with: data))
+        let total = getDouble(from: resolveValue(element.properties["total"], with: data)) ?? 1
+        if let f = fraction { fraction = total > 0 ? f / total : f }
+        if fraction == nil, let start = startTime, let end = endTime, end > start {
+            let now = Date().timeIntervalSince1970 * 1000
+            fraction = max(0, min(1, (end - now) / (end - start)))
+        }
+        let remaining = CGFloat(max(0, min(1, fraction ?? 1)))
+
+        Logger.viewCycle.error("📀 buildCircularTimerView -> remaining: \(remaining) paused: \(paused)")
+
+        let tint = Color(hex: color)
+        let cg = CGFloat(size)
+
+        // While running, hand the countdown window to the system so it animates
+        // the ring continuously without us recreating the activity (the static
+        // `trim` ring below only updates on start/pause/resume). Circular
+        // ProgressView support for `timerInterval` is iOS-version dependent; if a
+        // given OS renders it static, the worst case is what we had before.
+        if animated, !paused, let start = startTime, let end = endTime, end > start {
+            let startDate = Date(timeIntervalSince1970: start / 1000)
+            let endDate = Date(timeIntervalSince1970: end / 1000)
+            // The system circular indicator is ~20pt and can't be grown by frame
+            // or controlSize, so scale it to the requested size. This only stays
+            // un-clipped when the caller centers it with margin (the big expanded
+            // ring) — hugging a region edge clips the scaled-up stroke.
+            return AnyView(
+                ProgressView(timerInterval: startDate...endDate, countsDown: true) {
+                    EmptyView()
+                } currentValueLabel: {
+                    EmptyView()
+                }
+                .progressViewStyle(.circular)
+                .tint(tint)
+                .scaleEffect(cg / 20.0)
+                .frame(width: cg, height: cg)
+            )
+        }
+
+        // SwiftUI centers a stroke on the circle's path, so half the line width
+        // bleeds past the frame and gets clipped by the tight Dynamic Island
+        // compact region (the ring looked flattened on one edge). Inset both
+        // circles by half the line width so the whole stroke stays in bounds.
+        let inset = lineWidth / 2
+
+        let ring = ZStack {
+            Circle()
+                .stroke(tint.opacity(0.25), lineWidth: lineWidth)
+                .padding(inset)
+            Circle()
+                .trim(from: 0, to: remaining)
+                .stroke(tint.opacity(paused ? 0.5 : 1), style: StrokeStyle(lineWidth: lineWidth, lineCap: .round))
+                .rotationEffect(.degrees(-90))
+                .padding(inset)
+            if paused {
+                Image(systemName: "pause.fill")
+                    .resizable()
+                    .scaledToFit()
+                    .frame(width: cg * 0.34, height: cg * 0.34)
+                    .foregroundColor(tint.opacity(0.85))
+            }
+        }
+        .frame(width: cg, height: cg)
+
+        return AnyView(ring)
+    }
 }
