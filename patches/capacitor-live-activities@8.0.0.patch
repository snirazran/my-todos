+
+    /// An auto-animating circular countdown ring, like Apple's Timer Live
+    /// Activity. When `startTime`+`endTime` are supplied (and not paused),
+    /// `ProgressView(timerInterval:)` with the circular style drains the ring on
+    /// its own — the system animates it smoothly to completion with no per-second
+    /// JS updates. When paused (or only `value`/`total` given) it renders a
+    /// static ring at the current fraction.
+    static func buildCircularTimerView(_ element: LayoutElement, _ data: [String: AnyCodable]) -> AnyView {
+        let color = getString(from: resolveValue(element.properties["color"], with: data)) ?? "#007AFF"
+        let size = getDouble(from: resolveValue(element.properties["size"], with: data)) ?? 22
+        let lineWidth = getDouble(from: resolveValue(element.properties["lineWidth"], with: data))
+        let paused = resolveValue(element.properties["paused"], with: data) as? Bool ?? false
+
+        let startTime = getDouble(from: resolveValue(element.properties["startTime"], with: data))
+        let endTime = getDouble(from: resolveValue(element.properties["endTime"], with: data))
+
+        Logger.viewCycle.error("📀 buildCircularTimerView -> start: \(startTime ?? 0) end: \(endTime ?? 0) paused: \(paused)")
+
+        let tint = Color(hex: color)
+
+        // Live, self-animating ring for the running state.
+        if !paused, let start = startTime, let end = endTime, end > start {
+            let startDate = Date(timeIntervalSince1970: start / 1000)
+            let endDate = Date(timeIntervalSince1970: end / 1000)
+            return AnyView(
+                ProgressView(timerInterval: startDate...endDate, countsDown: true) {
+                    EmptyView()
+                } currentValueLabel: {
+                    EmptyView()
+                }
+                .progressViewStyle(.circular)
+                .tint(tint)
+                .labelsHidden()
+                .frame(width: CGFloat(size), height: CGFloat(size))
+            )
+        }
+
+        // Static ring (paused / fallback): fraction from value/total, or from
+        // how much of the start…end window is left at render time.
+        var fraction = getDouble(from: resolveValue(element.properties["value"], with: data))
+        let total = getDouble(from: resolveValue(element.properties["total"], with: data)) ?? 1
+        if fraction != nil { fraction = fraction! / total }
+        if fraction == nil, let start = startTime, let end = endTime, end > start {
+            let now = Date().timeIntervalSince1970 * 1000
+            fraction = max(0, min(1, (end - now) / (end - start)))
+        }
+
+        let ring = ZStack {
+            Circle()
+                .stroke(tint.opacity(0.25), lineWidth: CGFloat(lineWidth ?? 3))
+            Circle()
+                .trim(from: 0, to: CGFloat(fraction ?? 1))
+                .stroke(tint, style: StrokeStyle(lineWidth: CGFloat(lineWidth ?? 3), lineCap: .round))
+                .rotationEffect(.degrees(-90))
+        }
+        .frame(width: CGFloat(size), height: CGFloat(size))
+
+        return AnyView(ring)
+    }
 }
